# Vereist voor AI-samenvatting (Univé vragenlijst). Zet je key in .env.local (niet committen).
OPENAI_API_KEY=

# Optioneel: model voor samenvatting (default: gpt-4o; bijv. gpt-5 of gpt-5-mini als beschikbaar)
# OPENAI_SUMMARIZE_MODEL=gpt-4o

# Optioneel: basis-URL voor metadata en OG (default: https://unive.salgai.nl)
# NEXT_PUBLIC_APP_URL=https://unive.salgai.nl
